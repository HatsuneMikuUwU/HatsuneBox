<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="250dp"
    android:layout_height="100dp"
    android:gravity="start|center"
    android:orientation="horizontal"
    android:padding="?android:attr/listPreferredItemPaddingEnd"
    android:scrollbars="horizontal">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="bottom|center"
        android:background="@drawable/uwu_bg_icon_2"
        android:backgroundTint="?attr/colorSecondaryContainer"
        android:gravity="bottom|center"
        android:orientation="vertical"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingBottom="3dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|center"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/badge_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center|top"
                android:layout_marginTop="7dp"
                android:scaleType="centerInside"
                app:tint="?attr/colorOnPrimary"
                tools:ignore="ContentDescription" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="20dp"
                android:layout_height="3dp"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="7dp"
                app:cardBackgroundColor="?attr/colorOnPrimary"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:gravity="start|center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/badge_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:textSize="17sp" />

        <io.nekohasekai.sagernet.widget.marquee.AutoMarqueeTextView
            android:id="@+id/badge_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
