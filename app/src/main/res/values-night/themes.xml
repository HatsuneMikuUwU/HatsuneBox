        <item name="tabTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="tabSelectedTextColor">?attr/colorPrimary</item>
        <item name="tabIndicatorColor">?attr/colorPrimary</item>
        <item name="tabRippleColor">?attr/colorPrimary</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeCloseDrawable">@drawable/ic_navigation_close</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="itemShapeAppearance">@style/ShapeAppearance.App.MediumComponent</item>

