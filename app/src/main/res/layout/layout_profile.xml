<?xml version="1.0" encoding="utf-8"?>
<!-- Structure mirrors MikuRay's item_recycler_main.xml -->
<LinearLayout
    android:gravity="center_vertical"
    android:id="@+id/item_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4.0dip"
    android:layout_marginBottom="4.0dip"
    android:layout_marginStart="16.0dip"
    android:layout_marginEnd="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_card"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorCard"
        app:cardCornerRadius="16.0dip"
        app:cardElevation="0.0dip"
        app:strokeColor="?colorOutlineVariant"
        app:strokeWidth="0.0dip"
        android:layerType="none">

        <LinearLayout
            android:id="@+id/layout_indicator"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">

            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/info_container"
                android:paddingTop="12.0dip"
                android:paddingBottom="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="4.0dip"
                android:paddingEnd="4.0dip">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingStart="8.0dip"
                    android:paddingEnd="8.0dip">

                    <!-- Name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textSize="17.0sp"
                            android:textColor="?colorOnSurface"
                            android:id="@+id/profile_name"
                            android:layout_width="0dip"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:ellipsize="end"
                            android:maxLines="1"
                            tools:text="@string/profile_name" />

                        <View
                            android:id="@+id/v_status_dot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="0dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Type chip + action buttons row -->
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4.0dip">

                        <com.google.android.material.chip.Chip
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?colorOnSecondaryContainer"
                            android:textSize="12.0sp"
                            android:id="@+id/profile_type"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="28.0dip"
                            android:checkable="false"
                            android:layout_marginEnd="8.0dip"
                            app:chipBackgroundColor="?colorSecondaryContainer"
                            app:chipMinTouchTargetSize="0.0dip" />

                        <View
                            android:layout_width="0.0dip"
                            android:layout_height="0.0dip"
                            android:layout_weight="1.0" />

                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:id="@+id/share"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:gravity="center"
                                android:background="@drawable/bg_icon_button"
                                android:focusable="true"
                                android:clickable="true"
                                android:contentDescription="@string/share"
                                android:nextFocusLeft="@id/info_container">

                                <LinearLayout
                                    android:id="@+id/share_layer"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center">

                                    <androidx.appcompat.widget.AppCompatImageView
                                        android:id="@+id/shareIcon"
                                        android:layout_width="20.0dip"
                                        android:layout_height="20.0dip"
                                        app:srcCompat="@drawable/ic_social_share" />
                                </LinearLayout>
                            </LinearLayout>

                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/edit"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:contentDescription="@string/edit"
                                android:background="@drawable/bg_icon_button"
                                android:focusable="true"
                                android:padding="10.0dip"
                                app:srcCompat="@drawable/ic_image_edit" />

                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/remove"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:contentDescription="@string/delete"
                                android:background="@drawable/bg_icon_button"
                                android:focusable="true"
                                android:padding="10.0dip"
                                android:visibility="gone"
                                app:srcCompat="@drawable/ic_action_delete" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Address + status/ping row (mirrors tv_statistics + tv_test_result) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4.0dip">

                        <TextView
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textSize="14.0sp"
                            android:textColor="?colorOnSurfaceVariant"
                            android:id="@+id/profile_address"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:ellipsize="end"
                            android:maxLines="1"
                            tools:text="@string/server_address" />

                        <TextView
                            android:id="@+id/profile_status"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textSize="14.0sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8.0dip"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:lines="1" />
                    </LinearLayout>

                    <!-- Network/security + traffic row (mirrors layout_network_security + tv_traffic) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2.0dip">

                        <LinearLayout
                            android:id="@+id/layout_network_security"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <TextView
                                android:id="@+id/tv_network"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textSize="11.0sp"
                                android:textColor="?colorOnSurfaceVariant"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6.0dip"
                                android:drawablePadding="3.0dip"
                                android:gravity="center_vertical"
                                android:visibility="gone"
                                android:lines="1"
                                tools:text="tcp"
                                tools:visibility="visible" />

                            <TextView
                                android:id="@+id/tv_security"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textSize="11.0sp"
                                android:textColor="?colorOnSurfaceVariant"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="3.0dip"
                                android:gravity="center_vertical"
                                android:visibility="gone"
                                android:lines="1"
                                tools:text="tls"
                                tools:visibility="visible" />
                        </LinearLayout>

                        <View
                            android:layout_width="0.0dip"
                            android:layout_height="0.0dip"
                            android:layout_weight="1.0" />

                        <TextView
                            android:id="@+id/traffic_text"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textSize="11.0sp"
                            android:textColor="?colorOnSurfaceVariant"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:lines="1"
                            tools:text="@string/traffic"
                            tools:visibility="visible" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
