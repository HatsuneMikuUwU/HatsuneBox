<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorBg"
    android:paddingBottom="8dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/menu_container_parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- banner + particles + profile header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="5dp"
                android:clipToPadding="false"
                app:cardBackgroundColor="?attr/colorCard"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="#00000000"
                        app:cardCornerRadius="19dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/img_banner_sheet"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:elevation="0dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/uwu_banner_sheet"
                            tools:ignore="ContentDescription" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.2"
                            android:background="@android:color/black" />

                        <com.neko.particlesdrawable.ParticlesView
                            android:id="@+id/particles_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:background="#00000000"
                            app:dotColor="?attr/colorPrimary"
                            app:frameDelayMillis="10"
                            app:lineColor="?attr/colorPrimary"
                            app:lineDistance="86dp"
                            app:lineThickness="1dp"
                            app:maxDotRadius="4dp"
                            app:minDotRadius="1dp"
                            app:numDots="60"
                            app:stepMultiplier="1.0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:gravity="bottom">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:layout_marginTop="16dp"
                                    android:layout_marginEnd="5dp"
                                    android:layout_marginBottom="16dp"
                                    android:gravity="center">

                                    <io.nekohasekai.sagernet.widget.ProfileBannerImageView
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:src="@drawable/uwu_banner_profile"
                                        app:siBorderColor="@android:color/white"
                                        app:siBorderWidth="3dp" />

                                </LinearLayout>

                                <RelativeLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="5dp"
                                    android:layout_marginEnd="5dp"
                                    android:paddingTop="16dp"
                                    android:paddingBottom="16dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical">

                                        <io.nekohasekai.sagernet.widget.marquee.UserNameTextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:ellipsize="marquee"
                                            android:marqueeRepeatLimit="marquee_forever"
                                            android:singleLine="true"
                                            android:textAppearance="?attr/textAppearanceTitleMedium"
                                            android:textColor="@android:color/white"
                                            android:textSize="17sp"
                                            android:textStyle="bold" />

                                        <io.nekohasekai.sagernet.widget.marquee.RandomText
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:ellipsize="marquee"
                                            android:marqueeRepeatLimit="marquee_forever"
                                            android:singleLine="true"
                                            android:textAppearance="?attr/textAppearanceTitleSmall"
                                            android:textColor="@android:color/white"
                                            android:textSize="14sp"
                                            android:textStyle="bold"
                                            uwu_runnable="false" />

                                    </LinearLayout>

                                </RelativeLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="5dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <io.nekohasekai.sagernet.widget.UwuHeaderIconView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:sectionIcon="@drawable/ic_baseline_more_vert_24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_more_menu"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />

            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-16dp"
                    android:layout_marginEnd="-16dp"
                    android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/quick_actions_expand_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:contentPadding="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                    app:strokeWidth="0dp">

                    <include
                        android:id="@+id/row_quick_actions_expand_header"
                        layout="@layout/uwu_item_bottom_sheet_menu_row" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/quick_actions_expand_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_connection_tcp_ping"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_connection_tcp_ping"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_connection_url_test"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_connection_url_test"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_update_subscription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_update_subscription"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/management_expand_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:contentPadding="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                    app:strokeWidth="0dp">

                    <include
                        android:id="@+id/row_management_expand_header"
                        layout="@layout/uwu_item_bottom_sheet_menu_row" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/management_expand_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_clear_traffic_statistics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="4.0dip"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_clear_traffic_statistics"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_remove_duplicate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_remove_duplicate"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_connection_test_clear_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_connection_test_clear_results"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/action_connection_test_delete_unavailable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorCard"
                        app:cardElevation="0dp"
                        app:cardPreventCornerOverlap="false"
                        app:contentPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Bottom"
                        app:strokeWidth="0dp">

                        <include
                            android:id="@+id/row_action_connection_test_delete_unavailable"
                            layout="@layout/uwu_item_bottom_sheet_menu_row" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:gravity="center_vertical">

                <io.nekohasekai.sagernet.widget.UwuHeaderIconView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="12dp"
                    app:sectionIcon="@drawable/ic_order_alphabetical_ascending" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/group_order"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_order_origin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:contentPadding="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Top"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="16dp">

                            <io.nekohasekai.sagernet.widget.DynamicShapeImageView
                                android:layout_width="45dp"
                                android:layout_height="45dp"
                                android:scaleType="centerCrop"
                                app:shapeBackgroundColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_order_numeric_ascending"
                                app:tint="?attr/colorOnPrimary"
                                tools:ignore="ContentDescription" />

                        </FrameLayout>

                        <CheckedTextView
                            android:id="@+id/action_order_origin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?android:attr/selectableItemBackground"
                            android:checkMark="?android:attr/listChoiceIndicatorSingle"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:text="@string/group_order_origin"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="17sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_order_by_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:contentPadding="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Middle"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="16dp">

                            <io.nekohasekai.sagernet.widget.DynamicShapeImageView
                                android:layout_width="45dp"
                                android:layout_height="45dp"
                                android:scaleType="centerCrop"
                                app:shapeBackgroundColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_order_alphabetical_ascending"
                                app:tint="?attr/colorOnPrimary"
                                tools:ignore="ContentDescription" />

                        </FrameLayout>

                        <CheckedTextView
                            android:id="@+id/action_order_by_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?android:attr/selectableItemBackground"
                            android:checkMark="?android:attr/listChoiceIndicatorSingle"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:text="@string/group_order_by_name"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="17sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_order_by_delay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:contentPadding="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CardView.Bottom"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="16dp">

                            <io.nekohasekai.sagernet.widget.DynamicShapeImageView
                                android:layout_width="45dp"
                                android:layout_height="45dp"
                                android:scaleType="centerCrop"
                                app:shapeBackgroundColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_sort"
                                app:tint="?attr/colorOnPrimary"
                                tools:ignore="ContentDescription" />

                        </FrameLayout>

                        <CheckedTextView
                            android:id="@+id/action_order_by_delay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?android:attr/selectableItemBackground"
                            android:checkMark="?android:attr/listChoiceIndicatorSingle"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:text="@string/group_order_by_delay"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="17sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
